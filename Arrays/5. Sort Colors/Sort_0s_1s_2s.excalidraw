      "boundElements": [],
      "updated": 1780038514414,
      "link": null,
      "locked": false,
      "text": "0's belong to (0 -- low-1) group i.e. extreme left\nso, we'll increment low++ so it sticks to the 1's group,\nwhich means, the low-1 absorbs that new 0 into it's\n0's group",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "0's belong to (0 -- low-1) group i.e. extreme left\nso, we'll increment low++ so it sticks to the 1's group, which means, the low-1 absorbs that new 0 into it's 0's group",
      "autoResize": false,
      "lineHeight": 1.25
    },
