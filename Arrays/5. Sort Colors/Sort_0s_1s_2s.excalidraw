      "locked": false,
      "text": "high+1 will absorb the 2 so we want to focus on the\nunsorted part so we'll do, high--",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "high+1 will absorb the 2 so we want to focus on the unsorted part so we'll do, high--",
      "autoResize": false,
      "lineHeight": 1.25
    },
