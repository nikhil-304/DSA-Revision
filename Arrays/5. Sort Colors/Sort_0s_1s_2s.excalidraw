      "locked": false,
      "text": "0      low-1  low    mid-1   mid, high    high+1      n-1\n^        ^     ^       ^       ^                ^          ^\n|         |     |        |       |                 |          |\n0...........0     1..........1       1                 2.............0\n                                 unsorted",
      "fontSize": 20,
