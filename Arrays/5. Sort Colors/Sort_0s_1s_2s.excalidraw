      "boundElements": [],
      "updated": 1779951646562,
      "link": null,
      "locked": false,
      "text": "mid, high i.e. mid <= high both are equal, and mid = 1, so\nmid++",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "mid, high i.e. mid <= high both are equal, and mid = 1, so mid++",
      "autoResize": false,
      "lineHeight": 1.25
    },
